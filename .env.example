# Variables d'environnement — DoniTalan MVP
# Copier ce fichier en .env.local et remplir les valeurs

# ============================================
# BASE DE DONNÉES (Supabase PostgreSQL)
# ============================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-très-long-et-aléatoire-ici"

# ============================================
# GOOGLE OAUTH (optionnel)
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# SMS / OTP — Africa's Talking
# ============================================
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_API_KEY="votre-cle-api-sandbox"
AFRICAS_TALKING_SENDER_ID="DoniTalan"

# ============================================
# EMAIL — Resend
# ============================================
RESEND_API_KEY="re_votre_cle_api"
EMAIL_FROM="noreply@donitalan.com"

# ============================================
# SUPABASE STORAGE
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-cle-anon"
SUPABASE_SERVICE_ROLE_KEY="votre-cle-service-role"

# ============================================
# PAIEMENT — Mode simulé (MVP)
# En production: remplacer par les vraies clés
# ============================================
PAYMENT_MODE="simulated"  # simulated | orange_money | wave | cinetpay

# CinetPay (pour intégration future cartes bancaires)
CINETPAY_APIKEY=""
CINETPAY_SITE_ID=""

# ============================================
# CARTOGRAPHIE — Mapbox
# ============================================
NEXT_PUBLIC_MAPBOX_TOKEN="pk.votre-token-mapbox"

# ============================================
# PUSH NOTIFICATIONS — OneSignal
# ============================================
NEXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""

# ============================================
# WHATSAPP BUSINESS (future intégration)
# ============================================
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_SUPPORT_NUMBER="+22370000000"

# ============================================
# CONFIGURATION BUSINESS
# ============================================
PLATFORM_COMMISSION_PERCENT="12"
CURRENCY_DEFAULT="XOF"
APP_NAME="DoniTalan"
APP_URL="https://donitalan.com"
